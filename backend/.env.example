# Database
DATABASE_URL=sqlite:///./distribution.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/distribution_db

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production-minimum-32-characters

# Environment
ENVIRONMENT=development
DEBUG=True

# CORS (comma-separated for production)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500